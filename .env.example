# BugVault — 完整配置参考
#
# 复制为 .env 后按需修改。所有参数均有合理默认值，
# 最小配置只需要 BUGVAULT_EVAL_LLM_API_KEY（可选的评估增强）。

# ═══════════════════════════════════════════════════════════════════
# 数据路径
# ═══════════════════════════════════════════════════════════════════
# LanceDB 向量库 + Markdown 归档的根目录（默认 ~/.bugvault）
# BUGVAULT_DATA_ROOT=~/.bugvault

# ═══════════════════════════════════════════════════════════════════
# Embedding 模型（本地 ONNX，无需 API）
# ═══════════════════════════════════════════════════════════════════
# BUGVAULT_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# BUGVAULT_EMBEDDING_DIM=512

# ═══════════════════════════════════════════════════════════════════
# 检索参数
# ═══════════════════════════════════════════════════════════════════
BUGVAULT_TOP_K=5
# BUGVAULT_MIN_SEMANTIC_SCORE=0.65
# BUGVAULT_ENABLE_RECENCY_DECAY=false
# BUGVAULT_SEMANTIC_WEIGHT=0.7
# BUGVAULT_RECENCY_WEIGHT=0.3
# BUGVAULT_RECENCY_HALF_LIFE_DAYS=90

# ═══════════════════════════════════════════════════════════════════
# 截断
# ═══════════════════════════════════════════════════════════════════
# BUGVAULT_MAX_RECORD_CHARS=4000
# BUGVAULT_TRUNCATION_LEVEL=1

# ═══════════════════════════════════════════════════════════════════
# 并发
# ═══════════════════════════════════════════════════════════════════
# BUGVAULT_THREAD_POOL_WORKERS=2

# ═══════════════════════════════════════════════════════════════════
# RAG 评估（可选 — 需要外部 LLM API）
# ═══════════════════════════════════════════════════════════════════
# 启用后，retrieve_bug_experience 返回带评分和评估说明的区块
BUGVAULT_ENABLE_RAG_EVAL=true
BUGVAULT_EVAL_LLM_API_KEY=
# BUGVAULT_EVAL_LLM_MODEL=gpt-4o-mini
# BUGVAULT_EVAL_LLM_BASE_URL=https://api.openai.com/v1
# BUGVAULT_EVAL_TOP_K=3

# ═══════════════════════════════════════════════════════════════════
# Claim-Level 熔断保护
# ═══════════════════════════════════════════════════════════════════
# 单次 session 中 claim_level 评估次数上限，超限自动降级为 simple
# BUGVAULT_MAX_CLAIM_EVALS_PER_SESSION=10

# ═══════════════════════════════════════════════════════════════════
# MCP 服务器
# ═══════════════════════════════════════════════════════════════════
# BUGVAULT_SERVER_NAME=bugvault
# BUGVAULT_SERVER_VERSION=1.0.0

# ═══════════════════════════════════════════════════════════════════
# 异步嵌入（后台 embedding + LanceDB 写入）
# ═══════════════════════════════════════════════════════════════════
# BUGVAULT_ENABLE_ASYNC_EMBEDDING=true

# ═══════════════════════════════════════════════════════════════════
# 反思工具（写入 CLAUDE.md 预防规则）
# ═══════════════════════════════════════════════════════════════════
# BUGVAULT_ENABLE_REFLECTION_TOOL=true
