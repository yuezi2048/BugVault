# BugVault
#
# Environment variables — copy to .env and adjust.
# Supports the BUGVAULT_ prefix (e.g. BUGVAULT_EMBEDDING_MODEL="...").

# ── Data paths ────────────────────────────────────────────────────
# Root directory for LanceDB database + markdown archive.
# BUGVAULT_DATA_ROOT=~/.bugvault

# ── Embedding model ───────────────────────────────────────────────
# BUGVAULT_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# ── Retrieval ─────────────────────────────────────────────────────
# BUGVAULT_TOP_K=5
# BUGVAULT_RECENCY_WEIGHT=0.3
# BUGVAULT_RECENCY_HALF_LIFE_DAYS=90

# ── Concurrency ───────────────────────────────────────────────────
# BUGVAULT_THREAD_POOL_WORKERS=2
